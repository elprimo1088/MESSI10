<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EuroLeague Interactive Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: Arial, sans-serif; background-color:#111; color:white; margin:0; padding:0; }
        .container-box { border-radius:10px; padding:20px; margin:20px auto; max-width:900px; text-align:center; background: rgba(30,30,30,0.95);}
        button, .btn-custom { cursor:pointer; margin:5px;}
        .page { display:none; }
        iframe { border-radius:10px; width:100%; }

        #loginPage { 
            background-image: url('euroleague.png');
            background-size: cover; 
            background-repeat: no-repeat; 
            background-position: center center; 
            height: 100vh; 
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
        #loginPage form { background: rgba(0,0,0,0.6); padding: 20px; border-radius:10px; width: 300px; }
        #statsPage img { width:100%; border-radius:10px; }
    </style>
</head>
<body>

<div id="loginPage">
    <form id="loginForm">
        <h3>Login</h3>
        <input type="email" id="email" placeholder="Email" class="form-control mb-2"
               pattern="^[a-zA-Z0-9._%+-]+@gmail\.com$"
               title="Email mora biti u formatu nesto@gmail.com"
               required>
        <input type="password" id="password" placeholder="Password" class="form-control mb-2" required>
        <button type="submit" class="btn btn-warning w-100 btn-custom" id="loginBtn">Login</button>
    </form>
</div>

<div id="menuPage" class="container-box page text-center">
    <h3>Choose Page</h3>
    <button class="btn btn-primary nav-btn" data-target="videoPage">Video Analysis</button>
    <button class="btn btn-primary nav-btn" data-target="keyPage">Key Moments</button>
    <button class="btn btn-primary nav-btn" data-target="statsPage">Player vs Team</button>
</div>

<div id="videoPage" class="container-box page">
    <button class="btn btn-light mb-3" onclick="showPage('menuPage')">Back to Menu</button>
    <h3>Video Analysis</h3>
    <iframe height="400" src="https://www.youtube.com/embed/rQQjdWNngLk" allowfullscreen></iframe>
</div>

<div id="keyPage" class="container-box page">
    <button class="btn btn-light mb-3" onclick="showPage('menuPage')">Back to Menu</button>
    <h3>Key Moments</h3>
    <div class="mb-2"><iframe height="300" src="https://www.youtube.com/embed/KtBOlJr8yJ0" allowfullscreen></iframe></div>
    <div><iframe height="300" src="https://www.youtube.com/embed/RP6AMhEf-pU" allowfullscreen></iframe></div>
</div>

<div id="statsPage" class="container-box page">
    <button class="btn btn-light mb-3" onclick="showPage('menuPage')">Back to Menu</button>
    <h3>Player vs Team Performance</h3>
    <img src="players.png" alt="Player Stats Table">
</div>

<script>
function showPage(pageId){
    document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
    document.getElementById(pageId).style.display = 'block';
}

document.getElementById('loginForm').addEventListener('submit', function(e){
    e.preventDefault();
    const email = document.getElementById('email');
    if(email.checkValidity()){
        document.getElementById('loginPage').style.display = 'none';
        showPage('menuPage');
    } else {
        email.reportValidity();
    }
});

document.querySelectorAll('.nav-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
        const target = btn.getAttribute('data-target');
        showPage(target);
    });
});
</script>
</body>
</html>
